<script>
  async function handleSubmit() {
    const name = document.getElementById('name').value.trim();
    const email = document.getElementById('email').value.trim();
    const whatsapp = document.getElementById('whatsapp').value.trim();
    const area = document.getElementById('area').value;

    if (!name || !email || !area) {
      alert('Por favor, preencha seu nome, e-mail e área de atuação.');
      return;
    }

    if (!email.includes('@') || !email.includes('.')) {
      alert('Por favor, insira um e-mail válido.');
      return;
    }

    const btn = document.querySelector('.btn-submit');
    btn.disabled = true;
    btn.innerHTML = '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg> Enviando...';

    const firstName = name.split(' ')[0];
    const lastName = name.split(' ').slice(1).join(' ') || '';

    const portalId = '50622190';
    const formId = '807f1508-9952-487e-aee3-78da1c230780';

    const payload = {
      fields: [
        { name: 'firstname', value: firstName },
        { name: 'lastname', value: lastName },
        { name: 'email', value: email },
        { name: 'phone', value: whatsapp },
        { name: 'jobtitle', value: area }
      ],
      context: {
        pageUri: window.location.href,
        pageName: 'Aula Gratuita - O Poder de Ser Mentora'
      }
    };

    try {
      const res = await fetch(`https://api.hsforms.com/submissions/v3/integration/submit/${portalId}/${formId}`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify(payload)
      });

      if (res.ok) {
        document.getElementById('form-area').style.display = 'none';
        document.getElementById('success-msg').style.display = 'block';
        window.scrollTo({ top: document.getElementById('inscricao').offsetTop - 40, behavior: 'smooth' });
      } else {
        const err = await res.json();
        console.error('HubSpot error:', err);
        btn.disabled = false;
        btn.innerHTML = '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg> Quero participar da aula gratuita';
        alert('Ocorreu um erro ao enviar. Por favor, tente novamente.');
      }
    } catch (e) {
      console.error(e);
      btn.disabled = false;
      btn.innerHTML = '<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg> Quero participar da aula gratuita';
      alert('Ocorreu um erro de conexão. Por favor, tente novamente.');
    }
  }

  document.querySelectorAll('a[href="#inscricao"]').forEach(link => {
    link.addEventListener('click', e => {
      e.preventDefault();
      document.getElementById('inscricao').scrollIntoView({ behavior: 'smooth' });
      setTimeout(() => document.getElementById('name').focus(), 700);
    });
  });

  const whatsappInput = document.getElementById('whatsapp');
  whatsappInput.addEventListener('input', function () {
    let v = this.value.replace(/\D/g, '');
    if (v.length <= 11) {
      v = v.replace(/^(\d{2})(\d)/g, '($1) $2');
      v = v.replace(/(\d{5})(\d{1,4})$/, '$1-$2');
    }
    this.value = v;
  });
</script>
